# Copy to .env for local dev (do NOT commit .env).

# Uptime Kuma base URL. Use *.railway.internal when deploying alongside Kuma on Railway.
KUMA_URL=http://uptime-kuma.railway.internal:3001

# The slug of the Kuma public status page (the part after /status/ in the URL).
STATUS_SLUG=tms360

# Telegram bot token from @BotFather.
BOT_TOKEN=123456:ABC-DEF_your-token-here

# Target chat ID — same one you use in Kuma's Telegram notifier.
CHAT_ID=123456789

# How often to refresh the pinned message, in seconds.
POLL_INTERVAL=60

# Title shown at the top of the pinned message.
TITLE=TMS360 Production

# Port the bot's HTTP server listens on (for /healthz). Railway sets PORT automatically.
PORT=3000
